<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit msg</title>
</head>
<body>
        <h2>Edit Your msg </h2>
        <p> id = <%= chat._id %></p>
        <p>chat sent from: <b><%= chat.from %></b> to : <b><%= chat.to %></b></p>

        <form method="POST" action="/chats/<%= chat._id %>?_method=PUT">
        <textarea name="msg" id="msg" rows="5" cols="30"> <%= chat.msg %></textarea>
        <br><br>
        <button>Edit</button>
    </form>
</body>
</html>